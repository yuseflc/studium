{
  "info": {
    "name": "Studium Backend - API Completa",
    "description": "Colección completa de API para Studium con todas las rutas organizadas por recurso",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 Autenticación",
      "item": [
        {
          "name": "Registrarse",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/signup",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"nuevoestudiante@ejemplo.com\", \"firstName\": \"Juan\", \"password\": \"SecurePass123\", \"captchaToken\": \"token_opcional\"}"
            }
          }
        },
        {
          "name": "Iniciar Sesión",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/callback/credentials",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"usuario@ejemplo.com\", \"password\": \"contraseña123\"}"
            }
          }
        },
        {
          "name": "Obtener Sesión",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/session"
          }
        },
        {
          "name": "Revocar Sesión Actual",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/session/revoke",
            "header": [
              {
                "key": "Cookie",
                "value": "next-auth.session-token={{session_cookie}}"
              }
            ]
          }
        },
        {
          "name": "Cerrar Sesión",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/signout",
            "header": [
              {
                "key": "Cookie",
                "value": "next-auth.session-token={{session_cookie}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "📚 Cursos",
      "item": [
        {
          "name": "Listar Cursos",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/courses?page=1&limit=20",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ]
          }
        },
        {
          "name": "Crear Curso",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/courses",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              },
              {
                "key": "Cookie",
                "value": "next-auth.session-token={{session_cookie}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Introducción al Desarrollo Web\", \"description\": \"Aprende HTML, CSS y JavaScript\", \"status\": \"borrador\"}"
            }
          }
        },
        {
          "name": "[id] Curso por ID",
          "item": [
            {
              "name": "Obtener Detalles del Curso",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/api/courses/{{course_id}}",
                "header": [
                  {
                    "key": "Cookie",
                    "value": "next-auth.session-token={{session_cookie}}"
                  }
                ]
              }
            },
            {
              "name": "Actualizar Curso",
              "request": {
                "method": "PATCH",
                "url": "{{base_url}}/api/courses/{{course_id}}",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{auth_token}}"
                  },
                  {
                    "key": "Cookie",
                    "value": "next-auth.session-token={{session_cookie}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"title\": \"Título del Curso Actualizado\", \"description\": \"Descripción actualizada\", \"status\": \"activo\"}"
                }
              }
            },
            {
              "name": "Eliminar Curso",
              "request": {
                "method": "DELETE",
                "url": "{{base_url}}/api/courses/{{course_id}}",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{auth_token}}"
                  },
                  {
                    "key": "Cookie",
                    "value": "next-auth.session-token={{session_cookie}}"
                  }
                ]
              }
            },
            {
              "name": "Inscribir Estudiante",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/api/courses/{{course_id}}/enroll",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "Authorization",
                    "value": "Bearer {{auth_token}}"
                  },
                  {
                    "key": "Cookie",
                    "value": "next-auth.session-token={{session_cookie}}"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\"studentId\": \"id_del_estudiante\"}"
                }
              }
            },
            {
              "name": "[teachers] Gestión de Profesores",
              "item": [
                {
                  "name": "Agregar Profesor",
                  "request": {
                    "method": "POST",
                    "url": "{{base_url}}/api/courses/{{course_id}}/teachers",
                    "header": [
                      {
                        "key": "Content-Type",
                        "value": "application/json"
                      },
                      {
                        "key": "Authorization",
                        "value": "Bearer {{auth_token}}"
                      },
                      {
                        "key": "Cookie",
                        "value": "next-auth.session-token={{session_cookie}}"
                      }
                    ],
                    "body": {
                      "mode": "raw",
                      "raw": "{\"teacherId\": \"id_del_profesor\"}"
                    }
                  }
                },
                {
                  "name": "Eliminar Profesor",
                  "request": {
                    "method": "DELETE",
                    "url": "{{base_url}}/api/courses/{{course_id}}/teachers",
                    "header": [
                      {
                        "key": "Authorization",
                        "value": "Bearer {{auth_token}}"
                      },
                      {
                        "key": "Cookie",
                        "value": "next-auth.session-token={{session_cookie}}"
                      }
                    ],
                    "body": {
                      "mode": "raw",
                      "raw": "{\"teacherId\": \"id_del_profesor\"}"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
