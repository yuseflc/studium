  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "URL base para las peticiones de la API"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string",
      "description": "Token de autorización obtenido al iniciar sesión"
    },
    {
      "key": "course_id",
      "value": "",
      "type": "string",
      "description": "ObjectId de MongoDB de un curso"
    },
    {
      "key": "subject_id",
      "value": "",
